{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BookReview",
  "type": "object",
  "required": ["cycle", "verdict", "summary", "findings"],
  "additionalProperties": false,
  "properties": {
    "cycle": { "type": "integer", "minimum": 1 },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "chunk_id", "severity", "evidence", "problem", "rewrite_direction", "acceptance_test"],
        "additionalProperties": false,
        "properties": {
          "finding_id": { "type": "string" },
          "chunk_id": { "type": "integer", "minimum": 0 },
          "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "evidence": { "type": "string" },
          "problem": { "type": "string" },
          "rewrite_direction": { "type": "string" },
          "acceptance_test": { "type": "string" }
        }
      }
    }
  }
}
