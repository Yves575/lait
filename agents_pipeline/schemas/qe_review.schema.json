{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QEReview",
  "type": "object",
  "required": ["chunk_id", "score", "verdict"],
  "additionalProperties": false,
  "properties": {
    "chunk_id": {
      "type": "integer",
      "minimum": 0
    },
    "score": {
      "type": ["number", "null"]
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    }
  }
}
